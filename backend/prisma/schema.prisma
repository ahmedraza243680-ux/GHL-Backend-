// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BusinessStatus {
  ACTIVE
  INACTIVE
}

enum LocationStatus {
  ACTIVE
  INACTIVE
}

enum PostType {
  UPDATE
  OFFER
  EVENT
}

enum PostStatus {
  DRAFT
  SCHEDULED
  POSTED
  PENDING
  PUBLISHED
  REJECTED
  FAILED
}

enum SiteStatus {
  PENDING
  ACTIVE
  INACTIVE
}

model Business {
  id            String         @id @default(cuid())
  name          String
  ghlAccountId  String         @unique
  status        BusinessStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  locations     Location[]
}

model Location {
  id                 String           @id @default(cuid())
  businessId         String
  business           Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  ghlLocationId      String           @unique
  googleLocationId   String?
  googleAccountId    String?
  timezone           String           @default("UTC")
  status             LocationStatus   @default(ACTIVE)
  requiresApproval   Boolean          @default(false)
  ghlLastPostDateFieldId String?
  ghlPostStatusFieldId   String?
  ghlApiKey              String?
  /// OAuth tokens for Google Business Profile (encrypt at rest in production)
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiresAt DateTime?
  createdAt          DateTime         @default(now())
  posts              Post[]
  media              Media[]
  auditLogs          AuditLog[]
  schedule           LocationSchedule?

  @@index([businessId])
}

model LocationSchedule {
  id            String   @id @default(cuid())
  locationId    String   @unique
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  postsPerWeek  Int      @default(3)
  postDays      String[] @default(["Monday", "Wednesday", "Friday"])
  postTime      String   @default("09:00")
  postTypes     String[] @default(["UPDATE", "OFFER", "VIDEO"])
  /// Per weekday: { "Monday": "UPDATE", "Tuesday": "OFFER", ... }
  postDayTypes  Json     @default("{}")
  /// Per weekday: { "Monday": "09:00", "Tuesday": "10:30", ... }
  postDayTimes  Json     @default("{}")
  timezone      String   @default("America/New_York")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Media {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  postType   PostType
  url        String
  createdAt  DateTime @default(now())

  @@index([locationId, postType])
}

model Post {
  id          String     @id @default(cuid())
  locationId  String
  location    Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  type        PostType
  content     String     @db.Text
  mediaUrl    String?
  scheduledAt DateTime?
  postedAt    DateTime?
  status      PostStatus @default(DRAFT)
  platform    String     @default("google")
  createdAt   DateTime   @default(now())

  @@index([locationId])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  details    Json?
  createdAt  DateTime @default(now())

  @@index([locationId])
  @@index([createdAt])
}

model Template {
  id           String          @id @default(cuid())
  name         String
  industry     String
  slug         String          @unique
  description  String?
  previewImage String?
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  sites        GeneratedSite[]
}

model IndustrySchema {
  id                 String   @id @default(cuid())
  industry           String   @unique
  displayName        String
  systemPrompt       String
  homePageSchema     String
  aboutPageSchema    String
  servicesPageSchema String
  contactPageSchema  String
  locationPageSchema String
  blogPageSchema     String
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model GeneratedSite {
  id              String         @id @default(cuid())
  businessName    String
  industry        String
  city            String
  state           String         @default("NJ")
  phone           String?
  email           String?
  description     String?
  slug            String         @unique
  templateId      String
  template        Template       @relation(fields: [templateId], references: [id])
  homeContent     String?
  aboutContent    String?
  servicesContent String?
  contactContent  String?
  blogContent     String?
  status          SiteStatus     @default(PENDING)
  primaryColor    String         @default("#1F2937")
  secondaryColor  String         @default("#F3F4F6")
  accentColor     String         @default("#6366F1")
  heroStyle       String         @default("dark")
  fontStyle       String         @default("modern")
  address         String?
  facebookUrl     String?
  instagramUrl    String?
  websiteUrl      String?
  logoUrl         String?
  locationPages   LocationPage[]
  contactSubmissions ContactSubmission[]
  servicePages    ServicePage[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ServicePage {
  id           String        @id @default(cuid())
  siteId       String
  site         GeneratedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  serviceSlug  String
  serviceTitle String
  content      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([siteId, serviceSlug])
}

model LocationPage {
  id        String        @id @default(cuid())
  siteId    String
  site      GeneratedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  city      String
  county    String
  state     String        @default("NJ")
  slug      String
  content   String?
  createdAt DateTime      @default(now())

  @@unique([siteId, slug])
}

model ContactSubmission {
  id        String        @id @default(cuid())
  siteId    String
  site      GeneratedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime      @default(now())

  @@index([siteId])
  @@index([createdAt])
}
